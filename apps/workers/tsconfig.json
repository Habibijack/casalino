{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": true,
    "paths": {
      "@casalino/db": ["../../packages/db/src"],
      "@casalino/db/schema": ["../../packages/db/src/schema"],
      "@casalino/shared": ["../../packages/shared/src"],
      "@casalino/email": ["../../packages/email/src"]
    }
  },
  "include": ["src/**/*"]
}
